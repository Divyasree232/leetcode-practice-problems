class Solution:
    def removeNthFromEnd(self, head, n):
        dummy = ListNode(0)
        dummy.next = head
        
        fast = slow = dummy
        
        # Step 1: Move fast n+1 steps
        for _ in range(n + 1):
            fast = fast.next
        
        # Step 2: Move both pointers
        while fast:
            fast = fast.next
            slow = slow.next
        
        # Step 3: Delete nth node
        slow.next = slow.next.next
        
        return dummy.next
