class Solution:
    def totalNQueens(self, n: int) -> int:
        self.count = 0  
        # Track used columns
        cols = [False] * n
        # Track used main diagonals (col - row)
        main_diag = [False] * (2 * n - 1)
        # Track used anti-diagonals (col + row)
        anti_diag = [False] * (2 * n - 1)  
        def backtrack(row):
            if row == n:
                self.count += 1
                return      
            for col in range(n):
                # Check if current position is valid
                if not cols[col] and not main_diag[col - row] and not anti_diag[col + row]:
                    # Place queen
                    cols[col] = True
                    main_diag[col - row] = True
                    anti_diag[col + row] = True
                    # Recurse to next row
                    backtrack(row + 1)         
                    # Remove queen (backtrack)
                    cols[col] = False
                    main_diag[col - row] = False
                    anti_diag[col + row] = False  
        backtrack(0)
        return self.count
