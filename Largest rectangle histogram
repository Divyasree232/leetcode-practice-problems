class Solution:
    def largestRectangleArea(self, heights):
        stack = []  # will store indices
        max_area = 0
        # Add a zero height at the end to process all elements
        heights.append(0)
        for i in range(len(heights)):
            while stack and heights[stack[-1]] > heights[i]:
                h = heights[stack.pop()]
                # width calculation
                if stack:
                    w = i - stack[-1] - 1
                else:
                    w = i
                max_area = max(max_area, h * w)
            stack.append(i)
        return max_area
