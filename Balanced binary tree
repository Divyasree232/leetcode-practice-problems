class Solution:
    def isBalanced(self, root):
        return self.checkHeight(root) != -1
    def checkHeight(self, node):
        if not node:
            return 0
        left = self.checkHeight(node.left)
        if left == -1:
            return -1
        right = self.checkHeight(node.right)
        if right == -1:
            return -1
        if abs(left - right) > 1:
            return -1
        return 1 + max(left, right)
